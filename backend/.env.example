# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/office_hours
DATABASE_URL_TEST=postgresql+asyncpg://postgres:password@localhost:5432/office_hours_test

# Security
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI/ML
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
DUPLICATE_SIMILARITY_THRESHOLD=0.75

# CORS (add frontend URL when ready)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# App
PROJECT_NAME=Office Hours Queue System
API_V1_PREFIX=/api/v1
